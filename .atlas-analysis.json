  "keyFeatures": [
    "Multi-provider aggregation with automatic fallback between Fixer.io, OpenExchange, and CurrencyAPI",
    "Smart Redis caching with 5-minute TTL to minimize API calls",
    "Clean 4-layer architecture (API, Application, Domain, Infrastructure)",
    "PostgreSQL persistence for historical rate tracking",
    "Exponential backoff retry logic for transient network errors",
    "Type-safe Pydantic validation with full type hints",
    "Parallel rate fetching with rate averaging for accuracy"
  ],
  "publicApiSurface": [
    "GET /api/convert/{from_currency}/{to_currency}/{amount}",
    "GET /api/rate/{from_currency}/{to_currency}",
    "GET /api/currencies"
  ]
